<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Event Reservation{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/flatly/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                     EventReservation
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarColor01"
                        aria-controls="navbarColor01"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                 Événements
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('admin_event_index') }}">
                                 Administration
                            </a>
                        </li>
                         <li class="nav-item">
                           <a class="nav-link" href="{{ path('admin_reservations_index') }}">
                                  Réservations
                           </a>
                         </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item">
                                <span class="nav-link">
                                     {{ app.user.email }}
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_logout') }}">
                                     Déconnexion
                                </a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">
                                     Connexion
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">
                                     Inscription
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {# Messages Flash #}
        <div class="container mt-3">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <div class="container mt-4">
            {% block body %}{% endblock %}
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        
        {# ============================================ #}
        {# FONCTIONS WEBAUTHN POUR PASSKEY              #}
        {# ============================================ #}
        <script>
        // 1. Convertir un buffer en texte base64url
        function bufferToBase64Url(buffer) {
            const bytes = new Uint8Array(buffer);
            let binary = '';
            for (let i = 0; i < bytes.byteLength; i++) {
                binary += String.fromCharCode(bytes[i]);
            }
            return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }

        // 2. Convertir un texte base64url en buffer
        function base64UrlToBuffer(base64url) {
            let base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
            while (base64.length % 4) {
                base64 += '=';
            }
            const binary = atob(base64);
            const bytes = new Uint8Array(binary.length);
            for (let i = 0; i < binary.length; i++) {
                bytes[i] = binary.charCodeAt(i);
            }
            return bytes.buffer;
        }

        // 3. Se connecter avec une Passkey
        async function loginWithPasskey() {
            console.log(' Connexion Passkey...');
            try {
                const reponse = await fetch('/api/auth/login/options', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (!reponse.ok) {
                    const erreur = await reponse.json();
                    throw new Error(erreur.error || 'Erreur de connexion');
                }
                
                const options = await reponse.json();
                
                const publicKey = {
                    ...options,
                    challenge: base64UrlToBuffer(options.challenge)
                };
                
                const authentification = await navigator.credentials.get({ publicKey });
                
                const donnees = {
                    id: authentification.id,
                    rawId: bufferToBase64Url(authentification.rawId),
                    response: {
                        clientDataJSON: bufferToBase64Url(authentification.response.clientDataJSON),
                        authenticatorData: bufferToBase64Url(authentification.response.authenticatorData),
                        signature: bufferToBase64Url(authentification.response.signature),
                        userHandle: authentification.response.userHandle ? bufferToBase64Url(authentification.response.userHandle) : null
                    },
                    type: authentification.type
                };
                
                const verification = await fetch('/api/auth/login/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ credential: donnees })
                });
                
                const resultat = await verification.json();
                
                if (!verification.ok) {
                    throw new Error(resultat.error || 'Échec de l\'authentification');
                }
                
                console.log(' Connexion réussie');
                return resultat;
                
            } catch (error) {
                console.error(' Erreur:', error);
                throw error;
            }
        }

        // 4. S'inscrire avec une Passkey
        async function registerPasskey(email, nomAffichage) {
            console.log(' Inscription Passkey...');
            try {
                const reponse = await fetch('/api/auth/register/options', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, displayName: nomAffichage })
                });
                
                if (!reponse.ok) {
                    const erreur = await reponse.json();
                    throw new Error(erreur.error || 'Erreur d\'inscription');
                }
                
                const options = await reponse.json();
                
                const publicKey = {
                    ...options,
                    challenge: base64UrlToBuffer(options.challenge),
                    user: {
                        ...options.user,
                        id: base64UrlToBuffer(options.user.id)
                    }
                };
                
                const credential = await navigator.credentials.create({ publicKey });
                
                const donnees = {
                    id: credential.id,
                    rawId: bufferToBase64Url(credential.rawId),
                    response: {
                        clientDataJSON: bufferToBase64Url(credential.response.clientDataJSON),
                        attestationObject: bufferToBase64Url(credential.response.attestationObject)
                    },
                    type: credential.type
                };
                
                const verification = await fetch('/api/auth/register/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, credential: donnees })
                });
                
                const resultat = await verification.json();
                
                if (!verification.ok) {
                    throw new Error(resultat.error || 'Échec de la vérification');
                }
                
                console.log('Inscription réussie');
                return resultat;
                
            } catch (error) {
                console.error('Erreur:', error);
                throw error;
            }
        }

        // Rendre les fonctions disponibles partout
        window.loginWithPasskey = loginWithPasskey;
        window.registerPasskey = registerPasskey;
        </script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>