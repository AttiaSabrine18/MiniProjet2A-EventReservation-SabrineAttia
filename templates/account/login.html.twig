{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="card shadow mt-4">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0"> Connexion</h4>
            </div>
            <div class="card-body">

                {# Erreur de connexion #}
                {% if error %}
                    <div class="alert alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {# ====== CONNEXION CLASSIQUE ====== #}
                <form method="post" action="{{ path('app_login') }}">
                    <div class="mb-3">
                        <label class="form-label"> Email</label>
                        <input type="email"
                               name="_username"
                               class="form-control"
                               value="{{ last_username }}"
                               placeholder="votre@email.com"
                               required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"> Mot de passe</label>
                        <input type="password"
                               name="_password"
                               class="form-control"
                               placeholder="Votre mot de passe"
                               required>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            Se connecter
                        </button>
                    </div>
                </form>

                {# Séparateur #}
                <div class="text-center my-3">
                    <span class="text-muted"> ou </span>
                </div>

                {# ====== CONNEXION PASSKEY ====== #}
                <div class="d-grid">
                    <button id="btn-passkey-login"
                            class="btn btn-outline-success">
                         Se connecter avec Passkey
                    </button>
                </div>

                <div id="passkey-status" class="mt-2"></div>

                <hr>

                <div class="text-center">
                    <small>
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}">S'inscrire</a>
                    </small>
                </div>

            </div>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.getElementById('btn-passkey-login').addEventListener('click', async () => {
    const status = document.getElementById('passkey-status');
    const btn    = document.getElementById('btn-passkey-login');

    btn.disabled = true;
    status.innerHTML = '<div class="alert alert-info"> Authentification en cours...</div>';

    try {
        const result = await loginWithPasskey();

        status.innerHTML = '<div class="alert alert-success"> Connexion réussie !</div>';

        // Redirige vers l'accueil après connexion
        setTimeout(() => { window.location.href = '/'; }, 1000);

    } catch (error) {
        status.innerHTML = `<div class="alert alert-danger"> ${error.message}</div>`;
        btn.disabled = false;
    }
});
</script>
{% endblock %}