{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}

<div class="row">

    <div class="col-md-5">
        {% if event.image %}
            <img src="{{ asset('uploads/events/' ~ event.image) }}"
                 class="img-fluid rounded shadow"
                 alt="{{ event.title }}">
        {% else %}
            <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center"
                 style="height: 300px; font-size: 5rem;">
            
            </div>
        {% endif %}

        <div class="card mt-3">
            <div class="card-body">
                <h6 class="card-title fw-bold"> Informations</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                         <strong>Date :</strong>
                        {{ event.date|date('d/m/Y à H:i') }}
                    </li>
                    <li class="mb-2">
                         <strong>Lieu :</strong> {{ event.location }}
                    </li>
                    <li>
                         <strong>Places restantes :</strong>
                        {% if event.seats > 0 %}
                            <span class="badge bg-success">{{ event.seats }}</span>
                        {% else %}
                            <span class="badge bg-danger">Complet</span>
                        {% endif %}
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-7">

        <h1 class="fw-bold">{{ event.title }}</h1>

        <div class="mt-3">
            <p class="lead">{{ event.description }}</p>
        </div>

        <div class="mt-4">
            {% if event.seats > 0 %}
                <a href="{{ path('app_event_reserve', {id: event.id}) }}"
                   class="btn btn-primary btn-lg">
                     Réserver ma place
                </a>
            {% else %}
                <button class="btn btn-secondary btn-lg" disabled>
                     Événement complet
                </button>
            {% endif %}

            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg ms-2">
                 Retour
            </a>
        </div>
    </div>

</div>

{% endblock %}