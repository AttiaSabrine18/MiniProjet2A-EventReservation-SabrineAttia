# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
APP_ENV=test
APP_SECRET=test_secret_key_for_testing_only

# Base de données de test (séparée de la vraie !)
DATABASE_URL="mysql://root:@127.0.0.1:3306/event_reservation_test?serverVersion=8.0&charset=utf8mb4"

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=1234
JWT_TOKEN_TTL=3600

# WebAuthn
APP_DOMAIN=localhost
WEBAUTHN_RP_NAME="Mon Application Test"

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Default URI pour les tests
DEFAULT_URI=http://localhost